---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getEntry } from 'astro:content';

const page = await getEntry('pages', 'aanbod');
const { meta, hero, signal_sprint, story_system, full_track, compare, faq, cta } = page.data;
---

<BaseLayout title={meta.title} description={meta.description}>
  <Nav />

  <main>

    <section class="page-hero">
      <div class="container">
        <span class="label">{hero.label}</span>
        <h1 set:html={hero.h1.replace('\n', '<br />')} />
        <p class="lead">{hero.lead}</p>
      </div>
    </section>

    <!-- Story Sprint -->
    <section class="offer-section" id="signal-sprint">
      <div class="container">
        <div class="offer-layout">
          <div class="offer-intro">
            <div class="offer-tag">
              <span class="label">{signal_sprint.label}</span>
              <h2>{signal_sprint.heading}</h2>
              <p class="offer-duration">{signal_sprint.duration}</p>
            </div>
            <p class="offer-lead">{signal_sprint.lead}</p>
            <p>{signal_sprint.body}</p>
            <div class="offer-for">
              <h4>Voor wie</h4>
              <p>{signal_sprint.for_who}</p>
            </div>
            <div class="offer-price-block">
              <span class="price">{signal_sprint.price}</span>
              <a href="/contact" class="btn-primary">Plan een call</a>
            </div>
          </div>
          <div class="offer-details">
            <div class="deliverable-block">
              <h4>Wat je krijgt</h4>
              <p>{signal_sprint.deliverables_intro}</p>
              <ul>
                {signal_sprint.deliverables.map((d: any) => (
                  <li><strong>{d.title}</strong><span>{d.desc}</span></li>
                ))}
              </ul>
            </div>
            <div class="process-block">
              <h4>Hoe het werkt</h4>
              <ol>
                {signal_sprint.process.map((step: string) => <li>{step}</li>)}
              </ol>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Story System -->
    <section class="offer-section offer-section--alt" id="story-system">
      <div class="container">
        <div class="offer-layout">
          <div class="offer-intro">
            <div class="offer-tag">
              <span class="label">{story_system.label}</span>
              <h2>{story_system.heading}</h2>
              <p class="offer-duration">{story_system.duration}</p>
            </div>
            <p class="offer-lead">{story_system.lead}</p>
            <p>{story_system.body}</p>
            <div class="offer-for">
              <h4>Voor wie</h4>
              <p>{story_system.for_who}</p>
            </div>
            <div class="offer-price-block">
              <span class="price">{story_system.price}</span>
              <a href="/contact" class="btn-primary">Plan een call</a>
            </div>
          </div>
          <div class="offer-details">
            <div class="deliverable-block">
              <h4>Wat je krijgt</h4>
              <p>{story_system.deliverables_intro}</p>
              <ul>
                {story_system.deliverables.map((d: any) => (
                  <li><strong>{d.title}</strong><span>{d.desc}</span></li>
                ))}
              </ul>
            </div>
            <div class="process-block">
              <h4>Hoe het werkt</h4>
              <ol>
                {story_system.process.map((step: string) => <li>{step}</li>)}
              </ol>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- The Full Story -->
    <section class="offer-section" id="full-track">
      <div class="container">
        <div class="full-track-inner">
          <div class="full-track-text">
            <span class="label">{full_track.label}</span>
            <h2>{full_track.heading}</h2>
            <p class="offer-duration">{full_track.duration}</p>
            {full_track.body.map((p: string) => <p>{p}</p>)}
            <div class="offer-price-block">
              <span class="price">{full_track.price}</span>
              <a href="/contact" class="btn-primary">Plan een call</a>
            </div>
          </div>
          <div class="full-track-includes">
            <h4>Inbegrepen</h4>
            <div class="includes-cols">
              <div>
                <p class="includes-title">Story Sprint</p>
                <ul>
                  {full_track.sprint_includes.map((item: string) => <li>{item}</li>)}
                </ul>
              </div>
              <div>
                <p class="includes-title">Story System</p>
                <ul>
                  {full_track.system_includes.map((item: string) => <li>{item}</li>)}
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Vergelijking -->
    <section class="section-compare">
      <div class="container">
        <div class="section-header">
          <span class="label">{compare.label}</span>
          <h2>{compare.heading}</h2>
        </div>
        <div class="compare-table">
          <div class="compare-header">
            <div class="compare-feature"></div>
            <div class="compare-col">Story Sprint</div>
            <div class="compare-col compare-col--featured">Story System</div>
            <div class="compare-col">The Full Story</div>
          </div>
          {[
            ['Narrative Positioning', true, false, true],
            ['Brand Storytelling', true, false, true],
            ['Signal Document', true, false, true],
            ['Narrative Activation', false, true, true],
            ['AI-workflows en promptsets', false, true, true],
            ['Contentstructuur en formats', false, true, true],
            ['Story sessions (3x)', false, true, true],
          ].map(([feature, sprint, system, full]) => (
            <div class="compare-row">
              <div class="compare-feature">{feature}</div>
              <div class="compare-col">{sprint ? '✓' : '—'}</div>
              <div class="compare-col compare-col--featured">{system ? '✓' : '—'}</div>
              <div class="compare-col">{full ? '✓' : '—'}</div>
            </div>
          ))}
          <div class="compare-row compare-row--price">
            <div class="compare-feature">Investering</div>
            <div class="compare-col">v.a. €7.500</div>
            <div class="compare-col compare-col--featured">v.a. €17.500</div>
            <div class="compare-col">v.a. €24.500</div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section-faq">
      <div class="container">
        <div class="section-header">
          <span class="label">{faq.label}</span>
          <h2>{faq.heading}</h2>
        </div>
        <div class="faq-list">
          {faq.items.map((item: any) => (
            <details class="faq-item">
              <summary>{item.question}</summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="section-cta">
      <div class="container">
        <div class="cta-inner">
          <h2>{cta.heading}</h2>
          <p>{cta.body}</p>
          <a href="/contact" class="btn-primary btn-large">{cta.button}</a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
  .page-hero {
    padding: 5rem 0 4rem;
    border-bottom: 1px solid var(--border);
  }

  .label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
  }

  h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    max-width: 700px;
  }

  .lead {
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 600px;
    line-height: 1.7;
  }

  /* Offer sections */
  .offer-section {
    padding: 5rem 0;
    border-bottom: 1px solid var(--border);
  }

  #signal-sprint {
    background: var(--color-1);
  }

  .offer-section--alt {
    background: var(--color-3);
  }

  .offer-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .offer-tag {
    margin-bottom: 1.5rem;
  }

  .offer-tag h2 {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    margin: 0.25rem 0 0.35rem;
  }

  .offer-duration {
    font-size: 0.875rem;
    color: var(--text-secondary);
    font-weight: 500;
  }

  .offer-lead {
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: 1rem;
    font-weight: 500;
  }

  .offer-intro p {
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1rem;
    font-size: 0.95rem;
  }

  .offer-for {
    margin-top: 1.5rem;
    padding: 1.25rem;
    background: var(--color-2);
    border-radius: 8px;
    border: 1px solid var(--border);
  }

  .offer-section--alt .offer-for {
    background: var(--color-2);
  }

  .offer-for h4 {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: 0.4rem;
  }

  .offer-for p {
    font-size: 0.875rem !important;
    margin-bottom: 0 !important;
  }

  .offer-price-block {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }

  .price {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.1rem;
  }

  /* Deliverables */
  .deliverable-block {
    margin-bottom: 2rem;
  }

  .deliverable-block h4,
  .process-block h4 {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
  }

  .deliverable-block > p {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin-bottom: 1rem;
    line-height: 1.6;
  }

  .deliverable-block ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .deliverable-block li {
    display: flex;
    flex-direction: column;
    padding: 0.9rem 0;
    border-bottom: 1px solid var(--border);
  }

  .deliverable-block li strong {
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 0.15rem;
  }

  .deliverable-block li span {
    font-size: 0.825rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .process-block ol {
    list-style: none;
    counter-reset: steps;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .process-block li {
    counter-increment: steps;
    font-size: 0.875rem;
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .process-block li::before {
    content: counter(steps);
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--accent);
    background: var(--accent-light);
    width: 22px;
    height: 22px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  /* Full track */
  .full-track-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .full-track-text h2 {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    margin: 0.25rem 0 0.35rem;
  }

  .full-track-text p {
    color: var(--text-secondary);
    line-height: 1.7;
    font-size: 0.95rem;
    margin-bottom: 0.75rem;
  }

  .full-track-includes {
    background: var(--surface);
    border-radius: 12px;
    padding: 2rem;
  }

  .full-track-includes h4 {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: 1.25rem;
  }

  .includes-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .includes-title {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .includes-cols ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .includes-cols li {
    font-size: 0.825rem;
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .includes-cols li::before {
    content: '\2192';
    color: var(--accent);
    font-size: 0.75rem;
  }

  /* Compare */
  .section-compare {
    padding: 5rem 0;
    border-bottom: 1px solid var(--border);
    background: var(--color-1);
  }

  .section-header {
    margin-bottom: 2.5rem;
  }

  .section-header h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
  }

  .compare-table {
    border: 1.5px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }

  .compare-header,
  .compare-row {
    display: grid;
    grid-template-columns: 1fr repeat(3, 140px);
  }

  .compare-header {
    background: var(--surface);
    border-bottom: 1.5px solid var(--border);
  }

  .compare-header > div {
    padding: 1rem 1.25rem;
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 700;
  }

  .compare-row {
    border-bottom: 1px solid var(--border);
  }

  .compare-row:last-child {
    border-bottom: none;
  }

  .compare-feature {
    padding: 0.875rem 1.25rem;
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  .compare-col {
    padding: 0.875rem 1.25rem;
    font-size: 0.875rem;
    text-align: center;
    color: var(--text-secondary);
  }

  .compare-col--featured {
    background: var(--accent-light);
    color: var(--text);
    font-weight: 600;
  }

  .compare-row--price .compare-feature {
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--text);
  }

  .compare-row--price .compare-col {
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--text);
    font-size: 0.875rem;
  }

  /* FAQ */
  .section-faq {
    padding: 5rem 0;
    border-bottom: 1px solid var(--border);
    background: var(--color-3);
  }

  .faq-list {
    max-width: 720px;
    display: flex;
    flex-direction: column;
  }

  .faq-item {
    border-bottom: 1px solid var(--border);
  }

  .faq-item:first-child {
    border-top: 1px solid var(--border);
  }

  .faq-item summary {
    list-style: none;
    padding: 1.25rem 0;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .faq-item summary::-webkit-details-marker { display: none; }

  .faq-item summary::after {
    content: '+';
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--text-secondary);
    flex-shrink: 0;
    transition: transform 0.2s;
  }

  .faq-item[open] summary::after {
    transform: rotate(45deg);
  }

  .faq-item p {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.7;
    padding-bottom: 1.25rem;
  }

  /* CTA */
  .section-cta {
    padding: 6rem 0;
  }

  .cta-inner {
    background: var(--surface);
    border-radius: 16px;
    padding: 4rem;
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
  }

  .cta-inner h2 {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    margin-bottom: 1rem;
  }

  .cta-inner p {
    color: var(--text-secondary);
    margin-bottom: 2rem;
    line-height: 1.65;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    background: var(--accent);
    color: #fff;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    transition: opacity 0.15s;
  }

  .btn-primary:hover { opacity: 0.85; }
  .btn-primary.btn-large { font-size: 1.05rem; padding: 0.9rem 2rem; }

  @media (max-width: 900px) {
    .offer-layout,
    .full-track-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .compare-header,
    .compare-row {
      grid-template-columns: 1fr repeat(3, 90px);
    }
  }

  @media (max-width: 640px) {
    .page-hero,
    .offer-section,
    .section-compare,
    .section-faq,
    .section-cta {
      padding: 3.5rem 0;
    }

    .compare-header,
    .compare-row {
      grid-template-columns: 1fr repeat(3, 70px);
    }

    .compare-header > div,
    .compare-feature,
    .compare-col {
      padding: 0.75rem 0.6rem;
      font-size: 0.75rem;
    }

    .cta-inner {
      padding: 2.5rem 1.5rem;
    }

    .includes-cols {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>
