---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Van ruis naar signaal">
  <Nav />

  <main>

    <!-- Hero -->
    <section class="hero">
      <div class="container">
        <div class="hero-inner">
          <p class="eyebrow">Narrative positioning · Brand storytelling · Story systems</p>
          <h1>Van ruis<br />naar signaal.</h1>
          <p class="lead">Chief Story helpt groeiende organisaties hun strategische verhaal scherp te krijgen en werkend te maken in merk, marketing, sales en AI.</p>
          <div class="hero-cta">
            <a href="/contact" class="btn-primary">Plan een Signal Call</a>
            <a href="/methode" class="btn-ghost">Bekijk de methode</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Probleem -->
    <section class="section-problem">
      <div class="container">
        <div class="problem-grid">
          <div class="problem-text">
            <h2>Je organisatie groeit.<br />Je verhaal niet altijd.</h2>
            <p>Er komen nieuwe diensten bij. Nieuwe markten. Nieuwe mensen. Nieuwe ambities. Wat ooit helder voelde, wordt langzaam diffuus.</p>
            <p>Sales vertelt het ene verhaal. Marketing het andere. De website voelt te klein. Content wordt geproduceerd, maar mist richting, persoonlijkheid en scherpte. En AI maakt de output sneller, maar niet automatisch beter.</p>
            <p class="signal-line">Dat is ruis.<br /><strong>Chief Story helpt je het signaal te vinden en te versterken.</strong></p>
          </div>
          <div class="problem-quotes">
            <blockquote>"We zijn niet meer wie we drie jaar geleden waren."</blockquote>
            <blockquote>"Iedereen begrijpt ons pas na een uur praten."</blockquote>
            <blockquote>"Sales, marketing en directie vertellen niet hetzelfde verhaal."</blockquote>
            <blockquote>"We produceren veel, maar het voelt versnipperd."</blockquote>
          </div>
        </div>
      </div>
    </section>

    <!-- Methode -->
    <section class="section-method">
      <div class="container">
        <div class="section-header">
          <span class="label">De methode</span>
          <h2>In 3 stappen van ruis naar signaal</h2>
        </div>
        <div class="steps">
          <div class="step">
            <span class="step-number">01</span>
            <h3>Narrative Positioning</h3>
            <p class="step-tagline">Claim the narrative</p>
            <p>We bepalen welk grotere verhaal je merk kan claimen. Welke spanning je lost op. Welke positie nog vrij is in je markt.</p>
          </div>
          <div class="step">
            <span class="step-number">02</span>
            <h3>Brand Storytelling</h3>
            <p class="step-tagline">Craft the story</p>
            <p>We vertalen die positie naar een helder merkverhaal en concrete kernboodschappen. Taal die werkt in pitch, website, sales en marketing.</p>
          </div>
          <div class="step">
            <span class="step-number">03</span>
            <h3>Narrative Activation</h3>
            <p class="step-tagline">Build the system</p>
            <p>We bouwen het systeem waarmee je team dat verhaal consequent gebruikt in content, sales, marketing en AI-workflows.</p>
          </div>
        </div>
        <div class="method-cta">
          <a href="/methode" class="btn-outline">Hoe de methode werkt</a>
        </div>
      </div>
    </section>

    <!-- Aanbod -->
    <section class="section-offer">
      <div class="container">
        <div class="section-header">
          <span class="label">Het aanbod</span>
          <h2>Kies je route</h2>
        </div>
        <div class="offer-grid">
          <div class="offer-card">
            <div class="offer-header">
              <h3>Signal Sprint</h3>
              <span class="duration">1 maand</span>
            </div>
            <p>Van strategische ruis naar een helder merkverhaal. Positionering, brand story en kernboodschappen in één compact Signal Document.</p>
            <ul class="deliverables">
              <li>Narrative positionering</li>
              <li>Brand story</li>
              <li>Messaging pillars</li>
              <li>Kernzinnen voor merk, pitch en website</li>
            </ul>
            <div class="offer-footer">
              <span class="price">Vanaf €8.500</span>
              <a href="/contact" class="btn-primary">Plan een Signal Call</a>
            </div>
          </div>

          <div class="offer-card offer-card--featured">
            <div class="offer-badge">Meest gekozen</div>
            <div class="offer-header">
              <h3>Story System</h3>
              <span class="duration">3 maanden</span>
            </div>
            <p>Je verhaal structureel activeren in marketing, sales, content en AI. Vaste formats, AI-workflows en story sessions voor je team.</p>
            <ul class="deliverables">
              <li>Content- en messagingstructuur</li>
              <li>AI-workflows en promptsets</li>
              <li>Formats voor posts, artikelen, campaigns</li>
              <li>Maandelijkse story sessions</li>
            </ul>
            <div class="offer-footer">
              <span class="price">Vanaf €18.500</span>
              <a href="/contact" class="btn-primary">Plan een Signal Call</a>
            </div>
          </div>

          <div class="offer-card">
            <div class="offer-header">
              <h3>Full Track</h3>
              <span class="duration">4 maanden</span>
            </div>
            <p>De volledige route. Eerst het signaal vinden, daarna de versterker bouwen. Signal Sprint + Story System als één traject.</p>
            <ul class="deliverables">
              <li>Alles van de Signal Sprint</li>
              <li>Alles van het Story System</li>
              <li>Naadloze overgang tussen beide fases</li>
            </ul>
            <div class="offer-footer">
              <span class="price">Vanaf €24.500</span>
              <a href="/contact" class="btn-primary">Plan een Signal Call</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Voor wie -->
    <section class="section-audience">
      <div class="container">
        <div class="section-header">
          <span class="label">Voor wie</span>
          <h2>Voor wie Chief Story werkt</h2>
        </div>
        <div class="audience-grid">
          <div class="audience-card">
            <h3>Founders en CEO's</h3>
            <p>Je bedrijf is groter, complexer of volwassener geworden — maar je verhaal loopt achter. Je wil een narratief dat de volgende groeifase kan dragen.</p>
          </div>
          <div class="audience-card">
            <h3>Marketing leaders</h3>
            <p>Je organiseert campagnes, content en salesmateriaal, maar mist een helder narratief fundament. Je wil een systeem waarmee je team sneller en consistenter communiceert.</p>
          </div>
          <div class="audience-card">
            <h3>Kennisbedrijven</h3>
            <p>Je hebt veel expertise, maar vindt het lastig om die onderscheidend te verwoorden. Je wil autoriteit uitstralen zonder marketingpraat.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Waarom Chief Story -->
    <section class="section-why">
      <div class="container">
        <div class="why-inner">
          <div class="why-text">
            <span class="label">Waarom Chief Story</span>
            <h2>Storytelling is geen sausje. Het is een strategisch systeem.</h2>
            <p>Chief Story zit niet in de hoek van losse copywriting, contentproductie of merkworkshops. Het werk begint bij strategie: welk verhaal kun je claimen? Waarom is dat relevant? Hoe gebruik je het consequent?</p>
            <p>Dat vraagt om taalgevoel én strategisch inzicht. Om creatieve ervaring én commercieel begrip. Om AI-kennis die verder gaat dan prompts genereren.</p>
            <a href="/over" class="btn-outline">Over Joost Marsman</a>
          </div>
          <div class="why-proof">
            <div class="proof-item">
              <h4>Narrative positioning</h4>
              <p>Ervaring met positionering, merkverhalen en contentstrategie voor zakelijke dienstverleners, kennisorganisaties en scale-ups.</p>
            </div>
            <div class="proof-item">
              <h4>Creatieve geloofwaardigheid</h4>
              <p>Jarenlange ervaring als schrijver, copywriter en songwriter. Taal met ritme, spanning en betekenis — niet alleen correctheid.</p>
            </div>
            <div class="proof-item">
              <h4>AI-praktijkkennis</h4>
              <p>Ervaring met AI-workflows en custom GPT's voor contentcreatie, redactie, tone-of-voice checks en strategische messaging.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section-cta">
      <div class="container">
        <div class="cta-inner">
          <h2>Waar zit de ruis in jouw verhaal?</h2>
          <p>Plan een korte Signal Call. Dan kijken we waar je nu staat, waar het schuurt en welke route logisch is.</p>
          <a href="/contact" class="btn-primary btn-large">Plan een Signal Call</a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
  /* Hero */
  .hero {
    padding: 6rem 0 5rem;
    border-bottom: 1px solid var(--border);
  }

  .hero-inner {
    max-width: 720px;
  }

  .eyebrow {
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
  }

  h1 {
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
  }

  .lead {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: var(--text-secondary);
    max-width: 560px;
    margin-bottom: 2.5rem;
    line-height: 1.65;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
  }

  /* Buttons */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    background: var(--text);
    color: var(--bg);
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    transition: opacity 0.15s;
  }

  .btn-primary:hover {
    opacity: 0.85;
  }

  .btn-primary.btn-large {
    font-size: 1.05rem;
    padding: 0.9rem 2rem;
  }

  .btn-ghost {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text-secondary);
    padding: 0.75rem 0;
    border-bottom: 1px solid currentColor;
    transition: color 0.15s;
  }

  .btn-ghost:hover {
    color: var(--text);
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.7rem 1.4rem;
    border: 1.5px solid var(--border);
    border-radius: 8px;
    transition: border-color 0.15s, background 0.15s;
  }

  .btn-outline:hover {
    border-color: var(--text);
    background: var(--surface);
  }

  /* Section basics */
  .section-header {
    margin-bottom: 3rem;
  }

  .label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .section-header h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
  }

  /* Probleem */
  .section-problem {
    padding: 6rem 0;
    border-bottom: 1px solid var(--border);
  }

  .problem-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .problem-text h2 {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    margin-bottom: 1.5rem;
  }

  .problem-text p {
    color: var(--text-secondary);
    margin-bottom: 1rem;
    line-height: 1.7;
  }

  .signal-line {
    color: var(--text) !important;
    font-size: 1.05rem;
    border-left: 3px solid var(--accent);
    padding-left: 1rem;
    margin-top: 1.5rem;
  }

  .problem-quotes {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  blockquote {
    background: var(--surface);
    border-radius: 8px;
    padding: 1.1rem 1.25rem;
    font-size: 0.95rem;
    font-style: italic;
    color: var(--text-secondary);
    border-left: 2px solid var(--border);
  }

  /* Methode */
  .section-method {
    padding: 6rem 0;
    border-bottom: 1px solid var(--border);
  }

  .steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .step {
    padding: 2rem;
    background: var(--surface);
    border-radius: 12px;
  }

  .step-number {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--accent);
    display: block;
    margin-bottom: 1rem;
  }

  .step h3 {
    font-size: 1.2rem;
    margin-bottom: 0.25rem;
  }

  .step-tagline {
    font-size: 0.85rem;
    font-style: italic;
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
  }

  .step p:last-child {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  .method-cta {
    display: flex;
  }

  /* Aanbod */
  .section-offer {
    padding: 6rem 0;
    border-bottom: 1px solid var(--border);
  }

  .offer-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .offer-card {
    padding: 2rem;
    border: 1.5px solid var(--border);
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .offer-card--featured {
    border-color: var(--text);
    background: var(--surface);
  }

  .offer-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--text);
    color: var(--bg);
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.75rem;
    border-radius: 99px;
    white-space: nowrap;
  }

  .offer-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1rem;
  }

  .offer-header h3 {
    font-size: 1.25rem;
  }

  .duration {
    font-size: 0.8rem;
    color: var(--text-secondary);
    font-weight: 500;
  }

  .offer-card > p {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: 1.25rem;
    line-height: 1.65;
  }

  .deliverables {
    list-style: none;
    flex: 1;
    margin-bottom: 1.5rem;
  }

  .deliverables li {
    font-size: 0.875rem;
    color: var(--text-secondary);
    padding: 0.4rem 0;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .deliverables li::before {
    content: '\2192';
    color: var(--accent);
    font-size: 0.8rem;
    flex-shrink: 0;
  }

  .offer-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .price {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1rem;
  }

  /* Voor wie */
  .section-audience {
    padding: 6rem 0;
    border-bottom: 1px solid var(--border);
  }

  .audience-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .audience-card h3 {
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
  }

  .audience-card p {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  /* Waarom */
  .section-why {
    padding: 6rem 0;
    border-bottom: 1px solid var(--border);
  }

  .why-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .why-text .label {
    margin-bottom: 0.75rem;
  }

  .why-text h2 {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    margin-bottom: 1.25rem;
  }

  .why-text p {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .why-text .btn-outline {
    margin-top: 0.5rem;
  }

  .why-proof {
    display: flex;
    flex-direction: column;
  }

  .proof-item {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border);
  }

  .proof-item:first-child {
    border-top: 1px solid var(--border);
  }

  .proof-item h4 {
    font-size: 1rem;
    margin-bottom: 0.4rem;
  }

  .proof-item p {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  /* CTA */
  .section-cta {
    padding: 6rem 0;
  }

  .cta-inner {
    background: var(--surface);
    border-radius: 16px;
    padding: 4rem;
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
  }

  .cta-inner h2 {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    margin-bottom: 1rem;
  }

  .cta-inner p {
    color: var(--text-secondary);
    margin-bottom: 2rem;
    font-size: 1rem;
    line-height: 1.65;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .problem-grid,
    .why-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .steps,
    .offer-grid,
    .audience-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding: 4rem 0 3.5rem;
    }

    .section-problem,
    .section-method,
    .section-offer,
    .section-audience,
    .section-why,
    .section-cta {
      padding: 4rem 0;
    }

    .cta-inner {
      padding: 2.5rem 1.5rem;
    }
  }
</style>
