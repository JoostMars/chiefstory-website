---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getEntry } from 'astro:content';

const page = await getEntry('pages', 'home');
const { hero, problem, method, offer, audience, why, cta } = page.data;
---

<BaseLayout title="Van ruis naar signaal">
  <Nav />

  <main>

    <!-- Hero -->
    <section class="hero">
      <div class="container">
        <div class="hero-inner">
          <div class="hero-text">
            <p class="eyebrow">{hero.eyebrow}</p>
            <h1 set:html={hero.h1.replace('\n', '<br />')} />
            <p class="lead">{hero.lead}</p>
            <div class="hero-cta">
              <a href="/contact" class="btn-primary">{hero.cta_primary}</a>
              <a href="/methode" class="btn-ghost">{hero.cta_secondary}</a>
            </div>
          </div>
          <div class="hero-image">
            <img src="/joost.jpg" alt="Joost Marsman – Chief Story" />
          </div>
        </div>
      </div>
    </section>

    <!-- Probleem -->
    <section class="section-problem">
      <div class="container">
        <div class="problem-grid">
          <div class="problem-text">
            <h2 set:html={problem.heading.replace('\n', '<br />')} />
            {problem.body.map((p) => <p>{p}</p>)}
            <p class="signal-line">{problem.signal_line}<br /><strong>{problem.signal_emphasis}</strong></p>
          </div>
          <div class="problem-quotes">
            {problem.quotes.map((q) => <blockquote>"{q}"</blockquote>)}
          </div>
        </div>
      </div>
    </section>

    <!-- Methode -->
    <section class="section-method">
      <div class="container">
        <div class="section-header">
          <span class="label">{method.label}</span>
          <h2>{method.heading}</h2>
        </div>
        <div class="steps">
          {method.steps.map((step) => (
            <div class="step">
              <span class="step-number">{step.number}</span>
              <h3>{step.title}</h3>
              <p class="step-tagline">{step.tagline}</p>
              <p>{step.body}</p>
            </div>
          ))}
        </div>
        <div class="method-cta">
          <a href="/methode" class="btn-outline">{method.cta}</a>
        </div>
      </div>
    </section>

    <!-- Waarom Chief Story -->
    <section class="section-why">
      <div class="container">
        <div class="why-inner">
          <div class="why-text">
            <span class="label">{why.label}</span>
            <h2>{why.heading}</h2>
            {why.body.map((p) => <p>{p}</p>)}
            <a href="/over" class="btn-outline">{why.cta}</a>
          </div>
          <div class="why-proof">
            {why.proof.map((item) => (
              <div class="proof-item">
                <h4>{item.title}</h4>
                <p>{item.body}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Aanbod -->
    <section class="section-offer">
      <div class="container">
        <div class="section-header">
          <span class="label">{offer.label}</span>
          <h2>{offer.heading}</h2>
        </div>
        <div class="offer-grid">
          {offer.cards.map((card) => (
            <div class="offer-card offer-card--featured">
              <div class="offer-badge">{card.duration}</div>
              <div class="offer-header">
                <h3>{card.title}</h3>
              </div>
              <p>{card.description}</p>
              <ul class="deliverables">
                {card.deliverables.map((d) => <li>{d}</li>)}
              </ul>
              <div class="offer-footer">
                <a href={`/aanbod#${card.title.toLowerCase().replace(/ /g, '-')}`} class="btn-outline">Lees meer</a>
              </div>
            </div>
          ))}
        </div>
        <div class="method-cta">
          <a href="/aanbod" class="btn-outline">{offer.cta}</a>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section-cta">
      <div class="container">
        <div class="cta-inner">
          <h2>{cta.heading}</h2>
          <p>{cta.body}</p>
          <a href="/contact" class="btn-primary btn-large">{cta.button}</a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
  /* Hero */
  .hero {
    padding: 6rem 0 5rem;
    border-bottom: 1px solid var(--border);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 500px;
    gap: 4rem;
    align-items: center;
  }

  .hero-text {
    max-width: 600px;
  }

  .hero-image {
    position: relative;
  }

  .hero-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .eyebrow {
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
  }

  h1 {
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
  }

  .lead {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: var(--text-secondary);
    max-width: 560px;
    margin-bottom: 2.5rem;
    line-height: 1.65;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
  }

  /* Buttons */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    background: var(--accent);
    color: #fff;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    transition: opacity 0.15s;
  }

  .btn-primary:hover {
    opacity: 0.85;
  }

  .btn-primary.btn-large {
    font-size: 1.05rem;
    padding: 0.9rem 2rem;
  }

  .btn-ghost {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text-secondary);
    padding: 0.75rem 0;
    border-bottom: 1px solid currentColor;
    transition: color 0.15s;
  }

  .btn-ghost:hover {
    color: var(--text);
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.7rem 1.4rem;
    border: 1.5px solid var(--border);
    border-radius: 8px;
    transition: border-color 0.15s, background 0.15s;
  }

  .btn-outline:hover {
    border-color: var(--text);
    background: var(--surface);
  }

  /* Section basics */
  .section-header {
    margin-bottom: 3rem;
  }

  .label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .section-header h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
  }

  /* Probleem */
  .section-problem {
    padding: 6rem 0;
    border-bottom: 1px solid var(--border);
    background: var(--color-1);
  }

  .problem-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .problem-text h2 {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    margin-bottom: 1.5rem;
  }

  .problem-text p {
    color: var(--text-secondary);
    margin-bottom: 1rem;
    line-height: 1.7;
  }

  .signal-line {
    color: var(--text) !important;
    font-size: 1.05rem;
    border-left: 3px solid var(--accent);
    padding-left: 1rem;
    margin-top: 1.5rem;
  }

  .problem-quotes {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  blockquote {
    background: var(--color-2);
    border-radius: 8px;
    padding: 1.1rem 1.25rem;
    font-size: 0.95rem;
    font-style: italic;
    color: var(--text-secondary);
    border-left: 2px solid var(--accent);
  }

  /* Methode */
  .section-method {
    padding: 6rem 0;
    border-bottom: 1px solid var(--border);
    background: var(--color-3);
  }

  .steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .step {
    padding: 2rem;
    background: var(--color-2);
    border: 1.5px solid var(--border);
    border-radius: 12px;
  }

  .step-number {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--accent);
    display: block;
    margin-bottom: 1rem;
  }

  .step h3 {
    font-size: 1.2rem;
    margin-bottom: 0.25rem;
  }

  .step-tagline {
    font-size: 0.85rem;
    font-style: italic;
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
  }

  .step p:last-child {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  .method-cta {
    display: flex;
    margin-top: 3rem;
  }

  /* Aanbod */
  .section-offer {
    padding: 6rem 0;
    border-bottom: 1px solid var(--border);
    background: var(--color-3);
  }

  .offer-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .offer-card {
    padding: 2rem;
    border: 1.5px solid var(--border);
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    position: relative;
    background: var(--color-2);
  }

  .offer-card--featured {
    border-color: var(--text);
    background: var(--color-2);
  }

  .offer-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--text);
    color: var(--bg);
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.75rem;
    border-radius: 99px;
    white-space: nowrap;
  }

  .offer-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1rem;
  }

  .offer-header h3 {
    font-size: 1.25rem;
  }

  .duration {
    font-size: 0.8rem;
    color: var(--text-secondary);
    font-weight: 500;
  }

  .offer-card > p {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: 1.25rem;
    line-height: 1.65;
  }

  .deliverables {
    list-style: none;
    flex: 1;
    margin-bottom: 1.5rem;
  }

  .deliverables li {
    font-size: 0.875rem;
    color: var(--text-secondary);
    padding: 0.4rem 0;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .deliverables li::before {
    content: '\2192';
    color: var(--accent);
    font-size: 0.8rem;
    flex-shrink: 0;
  }

  .offer-footer {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* Voor wie */
  .section-audience {
    padding: 6rem 0;
    border-bottom: 1px solid var(--border);
    background: var(--color-3);
  }

  .audience-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .audience-card h3 {
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
  }

  .audience-card p {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  /* Waarom */
  .section-why {
    padding: 6rem 0;
    border-bottom: 1px solid var(--border);
    background: var(--color-1);
  }

  .why-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .why-text .label {
    margin-bottom: 0.75rem;
  }

  .why-text h2 {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    margin-bottom: 1.25rem;
  }

  .why-text p {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .why-text .btn-outline {
    margin-top: 0.5rem;
  }

  .why-proof {
    display: flex;
    flex-direction: column;
  }

  .proof-item {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border);
  }

  .proof-item:first-child {
    border-top: 1px solid var(--border);
  }

  .proof-item h4 {
    font-size: 1rem;
    margin-bottom: 0.4rem;
  }

  .proof-item p {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  /* CTA */
  .section-cta {
    padding: 6rem 0;
  }

  .cta-inner {
    background: var(--surface);
    border-radius: 16px;
    padding: 4rem;
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
  }

  .cta-inner h2 {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    margin-bottom: 1rem;
  }

  .cta-inner p {
    color: var(--text-secondary);
    margin-bottom: 2rem;
    font-size: 1rem;
    line-height: 1.65;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .problem-grid,
    .why-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .steps,
    .offer-grid,
    .audience-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .hero-image img {
      width: 100%;
      height: auto;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding: 4rem 0 3.5rem;
    }

    .section-problem,
    .section-method,
    .section-offer,
    .section-audience,
    .section-why,
    .section-cta {
      padding: 4rem 0;
    }

    .cta-inner {
      padding: 2.5rem 1.5rem;
    }
  }
</style>
