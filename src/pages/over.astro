---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getEntry } from 'astro:content';

const page = await getEntry('pages', 'over');
const { meta, hero, story, perspective, manifesto, cta } = page.data;
---

<BaseLayout title={meta.title} description={meta.description}>
  <Nav />

  <main>

    <section class="page-hero">
      <div class="container">
        <div class="hero-grid">
          <div class="hero-text">
            <span class="label">{hero.label}</span>
            <h1 set:html={hero.h1.replace('\n', '<br />')} />
            <p class="lead">{hero.lead}</p>
          </div>
          <div class="hero-image">
            <img src="/joost2.jpg" alt="Joost Marsman – Chief Story" />
          </div>
        </div>
      </div>
    </section>

    <section class="section-story">
      <div class="container">
        <div class="story-grid">
          <div class="story-main">
            <h2>{story.heading}</h2>
            {story.body.map((p: string) => <p>{p}</p>)}
          </div>
          <div class="story-aside">
            {story.credentials.map((cred: any) => (
              <div class="credential">
                <h4>{cred.title}</h4>
                <ul>
                  {cred.items.map((item: string) => <li>{item}</li>)}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section-perspective">
      <div class="container">
        <div class="perspective-inner">
          <span class="label">{perspective.label}</span>
          <div class="perspective-grid">
            {perspective.items.map((item: any) => (
              <div class="perspective-item">
                <h3>{item.title}</h3>
                <p>{item.body}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section-manifesto">
      <div class="container">
        <div class="manifesto-inner">
          <blockquote>
            <p>"{manifesto.quote}"</p>
            <cite>{manifesto.cite}</cite>
          </blockquote>
        </div>
      </div>
    </section>

    <section class="section-cta">
      <div class="container">
        <div class="cta-inner">
          <h2>{cta.heading}</h2>
          <p>{cta.body}</p>
          <a href="/contact" class="btn-primary btn-large">{cta.button}</a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
  .page-hero {
    padding: 5rem 0 4rem;
    border-bottom: 1px solid var(--border);
  }

  .label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
  }

  h1 {
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin-bottom: 1.5rem;
    max-width: 600px;
  }

  .lead {
    font-size: 1.05rem;
    color: var(--text-secondary);
    max-width: 560px;
    line-height: 1.7;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 5rem;
    align-items: center;
  }

  .hero-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Story */
  .section-story {
    padding: 5rem 0;
    border-bottom: 1px solid var(--border);
    background: var(--color-1);
  }

  .story-grid {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 5rem;
    align-items: start;
  }

  .story-main h2 {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    margin-bottom: 1.25rem;
  }

  .story-main p {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.75;
    margin-bottom: 1rem;
  }

  .credential {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--border);
  }

  .credential:first-child {
    border-top: 1px solid var(--border);
  }

  .credential h4 {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
  }

  .credential ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .credential li {
    font-size: 0.875rem;
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .credential li::before {
    content: '\2192';
    color: var(--accent);
    font-size: 0.75rem;
  }

  /* Perspective */
  .section-perspective {
    padding: 5rem 0;
    border-bottom: 1px solid var(--border);
    background: var(--color-3);
  }

  .perspective-inner .label {
    margin-bottom: 2.5rem;
  }

  .perspective-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
  }

  .perspective-item {
    padding: 2rem;
    border-bottom: 1px solid var(--border);
    border-right: 1px solid var(--border);
  }

  .perspective-item:nth-child(2n) {
    border-right: none;
  }

  .perspective-item:nth-child(3),
  .perspective-item:nth-child(4) {
    border-bottom: none;
  }

  .perspective-item h3 {
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
  }

  .perspective-item p {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  /* Manifesto */
  .section-manifesto {
    padding: 5rem 0;
    border-bottom: 1px solid var(--border);
    background: var(--color-1);
  }

  .manifesto-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  blockquote {
    border-left: 3px solid var(--accent);
    padding-left: 2rem;
  }

  blockquote p {
    font-family: var(--font-heading);
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    font-weight: 500;
    line-height: 1.5;
    letter-spacing: -0.01em;
    margin-bottom: 1rem;
  }

  cite {
    font-size: 0.875rem;
    color: var(--text-secondary);
    font-style: normal;
  }

  /* CTA */
  .section-cta {
    padding: 6rem 0;
  }

  .cta-inner {
    background: var(--surface);
    border-radius: 16px;
    padding: 4rem;
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
  }

  .cta-inner h2 {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    margin-bottom: 1rem;
  }

  .cta-inner p {
    color: var(--text-secondary);
    margin-bottom: 2rem;
    line-height: 1.65;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    background: var(--accent);
    color: #fff;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    transition: opacity 0.15s;
  }

  .btn-primary:hover { opacity: 0.85; }
  .btn-primary.btn-large { font-size: 1.05rem; padding: 0.9rem 2rem; }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }

    .story-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  @media (max-width: 640px) {
    .page-hero,
    .section-story,
    .section-perspective,
    .section-manifesto,
    .section-cta {
      padding: 3.5rem 0;
    }

    .perspective-grid {
      grid-template-columns: 1fr;
    }

    .perspective-item {
      border-right: none;
    }

    .perspective-item:last-child {
      border-bottom: none;
    }

    .cta-inner {
      padding: 2.5rem 1.5rem;
    }
  }
</style>
