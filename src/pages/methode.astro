---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getEntry } from 'astro:content';

const page = await getEntry('pages', 'methode');
const { meta, hero, intro, steps, ai, note, cta } = page.data;
---

<BaseLayout title={meta.title} description={meta.description}>
  <Nav />

  <main>

    <section class="page-hero">
      <div class="container">
        <span class="label">{hero.label}</span>
        <h1 set:html={hero.h1.replace('\n', '<br />')} />
        <p class="lead">{hero.lead}</p>
      </div>
    </section>

    <section class="section-intro">
      <div class="container">
        <div class="intro-grid">
          <div>
            <h2>{intro.heading}</h2>
            {intro.body.map((p: string) => <p>{p}</p>)}
          </div>
          <div class="intro-aside">
            <p class="quote-big">"{intro.quote}"</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section-steps">
      <div class="container">
        {steps.map((step: any) => (
          <div class="step-block">
            <div class="step-meta">
              <span class="step-number">{step.number}</span>
              <span class="step-phase">{step.phase}</span>
              <span class="step-tagline">{step.tagline}</span>
            </div>
            <div class="step-content">
              <h2>{step.heading}</h2>
              {step.body.map((p: string) => <p>{p}</p>)}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="section-ai">
      <div class="container">
        <div class="ai-inner">
          <div>
            <span class="label">{ai.label}</span>
            <h2>{ai.heading}</h2>
            {ai.body.map((p: string) => <p>{p}</p>)}
          </div>
          <div class="ai-list">
            {ai.items.map((item: any) => (
              <div class="ai-item">
                <h4>{item.title}</h4>
                <p>{item.body}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section-note">
      <div class="container">
        <div class="note-inner">
          <h3>{note.heading}</h3>
          {note.body.map((p: string) => <p>{p}</p>)}
          <a href="/aanbod" class="btn-outline">{note.cta}</a>
        </div>
      </div>
    </section>

    <section class="section-cta">
      <div class="container">
        <div class="cta-inner">
          <h2>{cta.heading}</h2>
          <p>{cta.body}</p>
          <a href="/contact" class="btn-primary btn-large">{cta.button}</a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
  .page-hero {
    padding: 5rem 0 4rem;
    border-bottom: 1px solid var(--border);
  }

  .label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
  }

  h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    max-width: 700px;
  }

  .lead {
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 600px;
    line-height: 1.7;
  }

  /* Intro */
  .section-intro {
    padding: 5rem 0;
    border-bottom: 1px solid var(--border);
    background: var(--color-1);
  }

  .intro-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .intro-grid h2 {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    margin-bottom: 1rem;
  }

  .intro-grid p {
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }

  .quote-big {
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.02em;
    color: var(--text);
    border-left: 3px solid var(--accent);
    padding-left: 1.5rem;
  }

  /* Steps */
  .section-steps {
    padding: 5rem 0;
    border-bottom: 1px solid var(--border);
    background: var(--color-3);
  }

  .step-block {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 4rem;
    padding: 4rem 0;
    border-bottom: 1px solid var(--border);
    align-items: start;
  }

  .step-block:first-child {
    padding-top: 0;
  }

  .step-block:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .step-meta {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    position: sticky;
    top: 5rem;
  }

  .step-number {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .step-phase {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
  }

  .step-tagline {
    font-size: 0.85rem;
    font-style: italic;
    color: var(--text-secondary);
  }

  .step-content h2 {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    margin-bottom: 1.25rem;
  }

  .step-content p {
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  /* AI */
  .section-ai {
    padding: 5rem 0;
    border-bottom: 1px solid var(--border);
    background: var(--color-1);
  }

  .ai-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .ai-inner h2 {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    margin-bottom: 1rem;
  }

  .ai-inner > div p {
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }

  .ai-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .ai-item {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--border);
  }

  .ai-item:first-child {
    border-top: 1px solid var(--border);
  }

  .ai-item h4 {
    font-size: 1rem;
    margin-bottom: 0.35rem;
  }

  .ai-item p {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* Note */
  .section-note {
    padding: 5rem 0;
    border-bottom: 1px solid var(--border);
  }

  .note-inner {
    max-width: 680px;
    background: var(--accent-light);
    border-radius: 12px;
    padding: 2.5rem;
    border-left: 3px solid var(--accent);
  }

  .note-inner h3 {
    font-size: 1.2rem;
    margin-bottom: 1rem;
  }

  .note-inner p {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }

  .note-inner .btn-outline {
    margin-top: 0.5rem;
  }

  /* CTA */
  .section-cta {
    padding: 6rem 0;
  }

  .cta-inner {
    background: var(--surface);
    border-radius: 16px;
    padding: 4rem;
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
  }

  .cta-inner h2 {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    margin-bottom: 1rem;
  }

  .cta-inner p {
    color: var(--text-secondary);
    margin-bottom: 2rem;
    line-height: 1.65;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    background: var(--accent);
    color: #fff;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    transition: opacity 0.15s;
  }

  .btn-primary:hover { opacity: 0.85; }

  .btn-primary.btn-large {
    font-size: 1.05rem;
    padding: 0.9rem 2rem;
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.7rem 1.4rem;
    border: 1.5px solid var(--border);
    border-radius: 8px;
    transition: border-color 0.15s, background 0.15s;
  }

  .btn-outline:hover {
    border-color: var(--text);
    background: var(--surface);
  }

  @media (max-width: 900px) {
    .intro-grid,
    .ai-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .step-block {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .step-meta {
      position: static;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.5rem 1.5rem;
      align-items: baseline;
    }
  }

  @media (max-width: 640px) {
    .page-hero,
    .section-intro,
    .section-steps,
    .section-ai,
    .section-note,
    .section-cta {
      padding: 3.5rem 0;
    }

    .cta-inner {
      padding: 2.5rem 1.5rem;
    }
  }
</style>
